# ClawChat Server — Environment Variables

# OpenClaw Gateway URL (default: ws://127.0.0.1:18789)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw Gateway auth token (required for real AI responses)
# Get this from: openclaw config get gateway.auth.token
OPENCLAW_AUTH_TOKEN=

# OpenClaw agent ID (optional, defaults to 'default')
# OPENCLAW_AGENT_ID=default

# Server port (default: 3001)
PORT=3001

# Client URL for CORS (default: http://localhost:5173)
CLIENT_URL=http://localhost:5173
