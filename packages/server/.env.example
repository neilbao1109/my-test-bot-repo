# ClawChat Server — Environment Variables
# See README.md for details on each connection mode.

# ── Mode 1: Local Gateway (default) ──
# Just set the auth token. Gateway is expected at ws://127.0.0.1:18789.
OPENCLAW_AUTH_TOKEN=

# ── Mode 2: Remote Gateway (direct URL) ──
# Uncomment and set both to connect directly to a remote Gateway.
# Requires the Gateway port to be exposed (e.g. via Tailscale / VPN).
# OPENCLAW_GATEWAY_URL=ws://your-server:18789
# OPENCLAW_AUTH_TOKEN=your_token

# ── Mode 3: Remote Gateway (auto SSH tunnel) ──
# Uncomment OPENCLAW_SSH_HOST to auto-create an SSH tunnel.
# ClawChat will forward a local port to the remote Gateway automatically.
# OPENCLAW_SSH_HOST=user@your-server
# OPENCLAW_SSH_PORT=22
# OPENCLAW_SSH_KEY=~/.ssh/id_ed25519
# OPENCLAW_REMOTE_GW_HOST=127.0.0.1
# OPENCLAW_REMOTE_GW_PORT=18789
# OPENCLAW_LOCAL_GW_PORT=0

# ── Agent config ──
# OPENCLAW_AGENT_ID=default

# ── Server config ──
PORT=3001
HOST=0.0.0.0

# CORS origin for Socket.IO (default: * = allow all)
# Set to a specific origin in production for security:
# CORS_ORIGIN=https://your-frontend.com
# CORS_ORIGIN=*
